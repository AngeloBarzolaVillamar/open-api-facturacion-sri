# =================================================
# Docker Ignore - Carbone API
# =================================================

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output (we build inside Docker)
dist
build

# Development files
.git
.gitignore
.vscode
.idea
*.md
!README.md

# Test files
test
*.spec.ts
*.test.ts
coverage
.nyc_output

# Environment files (we pass env vars at runtime)
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# Logs
logs
*.log

# Docker files (avoid recursion)
Dockerfile*
docker-compose*.yml
.dockerignore

# Data directories (mounted as volumes)
templates
pdfs
certs

# Temp files
.temp
.tmp
*.pid
*.seed
